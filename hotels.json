        .space-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, rgba(8, 8, 16, 0.75) 0%, rgba(8, 8, 16, 0.95) 100%);
            z-index: 1;
        }

        /* =============================================
           HEADER
           ============================================= */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 100;
            padding: 25px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(8, 8, 16, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(244, 162, 97, 0.1);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .logo-diamond {
            width: 28px;
            height: 28px;
            filter: drop-shadow(0 0 10px rgba(255, 232, 163, 0.5));
        }

        .logo-text {
            font-family: 'Cinzel', serif;
            font-size: 0.75rem;
            font-weight: 500;
            letter-spacing: 8px;
            text-transform: uppercase;
            color: #f4a261;
        }

        .back-link {
            font-family: 'Outfit', sans-serif;
            font-size: 0.8rem;
            color: #f8f9fa;
            text-decoration: none;
            opacity: 0.6;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .back-link:hover {
            opacity: 1;
            color: #f4a261;
        }

        /* =============================================
           MAIN CONTENT
           ============================================= */
        .main-content {
            position: relative;
            z-index: 50;
            padding-top: 100px;
        }

        /* =============================================
           HERO IMAGE
           ============================================= */
        .hero-image {
            width: 100%;
            height: 450px;
            background: url('https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1200') center center / cover no-repeat;
            position: relative;
        }

        .hero-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 200px;
            background: linear-gradient(to top, #080810 0%, transparent 100%);
        }

        .hero-badge {
            position: absolute;
            top: 30px;
            left: 30px;
            background: rgba(244, 162, 97, 0.95);
            color: #080810;
            font-family: 'Cinzel', serif;
            font-size: 0.65rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            padding: 12px 20px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .hero-badge::before {
            content: "✓";
            font-weight: bold;
        }

        /* =============================================
           HOTEL INFO CONTAINER
           ============================================= */
        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 25px 80px;
        }

        /* =============================================
           HOTEL HEADER
           ============================================= */
        .hotel-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 50px;
            margin-top: -60px;
            position: relative;
        }

        .hotel-title-section {
            flex: 1;
        }

        .hotel-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 3.2rem;
            font-weight: 300;
            margin-bottom: 12px;
            line-height: 1.1;
        }

        .hotel-location {
            font-size: 1rem;
            opacity: 0.5;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .hotel-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .hotel-tag {
            font-size: 0.7rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 8px 16px;
            background: rgba(244, 162, 97, 0.1);
            border: 1px solid rgba(244, 162, 97, 0.2);
            border-radius: 20px;
            color: #f4a261;
        }

        /* BOOKING BOX */
        .booking-box {
            background: rgba(28, 28, 52, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 35px;
            border: 1px solid rgba(244, 162, 97, 0.15);
            min-width: 320px;
            text-align: center;
        }

        .rating-large {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin-bottom: 25px;
        }

        .rating-score-large {
            background: #f4a261;
            color: #080810;
            font-family: 'Cinzel', serif;
            font-size: 1.4rem;
            font-weight: 600;
            padding: 15px 20px;
            border-radius: 12px;
        }

        .rating-details {
            text-align: left;
        }

        .rating-label {
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            font-weight: 400;
            margin-bottom: 3px;
        }

        .rating-count {
            font-size: 0.8rem;
            opacity: 0.5;
        }

        .price-large {
            margin-bottom: 25px;
        }

        .price-label {
            font-size: 0.75rem;
            opacity: 0.5;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .price-amount-large {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.8rem;
            color: #f4a261;
        }

        .price-amount-large span {
            font-size: 1.2rem;
            opacity: 0.6;
            color: #f8f9fa;
        }

        .book-direct-btn-large {
            width: 100%;
            padding: 20px 30px;
            font-family: 'Cinzel', serif;
            font-size: 0.8rem;
            font-weight: 500;
            letter-spacing: 4px;
            text-transform: uppercase;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, #f4a261 0%, #e07a5f 100%);
            color: #080810;
            cursor: pointer;
            transition: all 0.4s ease;
            margin-bottom: 15px;
        }

        .book-direct-btn-large:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(244, 162, 97, 0.4);
            letter-spacing: 6px;
        }

        .direct-note {
            font-size: 0.75rem;
            opacity: 0.5;
            font-style: italic;
        }

        /* =============================================
           CONTENT GRID
           ============================================= */
        .content-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 50px;
        }

        .content-card {
            background: rgba(28, 28, 52, 0.5);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 20px;
            padding: 35px;
            border: 1px solid rgba(244, 162, 97, 0.1);
        }

        .content-card.full-width {
            grid-column: 1 / -1;
        }

        .card-title {
            font-family: 'Cinzel', serif;
            font-size: 0.7rem;
            letter-spacing: 5px;
            text-transform: uppercase;
            color: #f4a261;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* =============================================
           VERIFIED INFO (THE HONEST TRUTH)
           ============================================= */
        .verified-section {
            background: rgba(74, 222, 128, 0.05);
            border: 1px solid rgba(74, 222, 128, 0.2);
        }

        .card-title.verified {
            color: #4ade80;
        }

        .verified-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }

        .verified-item {
            display: flex;
            gap: 15px;
        }

        .verified-icon {
            width: 45px;
            height: 45px;
            background: rgba(74, 222, 128, 0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .verified-content h4 {
            font-family: 'Outfit', sans-serif;
            font-size: 0.9rem;
            font-weight: 400;
            margin-bottom: 5px;
        }

        .verified-content p {
            font-size: 0.85rem;
            opacity: 0.6;
            line-height: 1.5;
        }

        .verified-content .highlight {
            color: #4ade80;
            opacity: 1;
            font-weight: 400;
        }

        /* =============================================
           DESCRIPTION
           ============================================= */
        .description-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.2rem;
            line-height: 1.8;
            opacity: 0.8;
            font-style: italic;
        }

        .description-text p {
            margin-bottom: 20px;
        }

        .description-text p:last-child {
            margin-bottom: 0;
        }

        /* =============================================
           BEST FOR
           ============================================= */
        .best-for-list {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .best-for-item {
            font-size: 0.85rem;
            padding: 10px 18px;
            background: rgba(244, 162, 97, 0.1);
            border: 1px solid rgba(244, 162, 97, 0.2);
            border-radius: 25px;
            color: #f4a261;
        }

        /* =============================================
           AMENITIES
           ============================================= */
        .amenities-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .amenity-item {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.9rem;
            opacity: 0.7;
        }

        .amenity-icon {
            font-size: 1.1rem;
        }

        /* =============================================
           GALLERY
           ============================================= */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
        }

        .gallery-image {
            width: 100%;
            height: 180px;
            background-size: cover;
            background-position: center;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .gallery-image:hover {
            transform: scale(1.03);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
        }

        /* =============================================
           NEIGHBORHOOD
           ============================================= */
        .neighborhood-text {
            font-size: 1rem;
            line-height: 1.8;
            opacity: 0.7;
            margin-bottom: 25px;
        }

        .nearby-list {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        .nearby-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.85rem;
            opacity: 0.6;
        }

        .nearby-item .distance {
            color: #f4a261;
            opacity: 1;
        }

        /* =============================================
           POLICIES
           ============================================= */
        .policies-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .policy-item {
            display: flex;
            justify-content: space-between;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .policy-label {
            font-size: 0.85rem;
            opacity: 0.5;
        }

        .policy-value {
            font-size: 0.9rem;
            font-weight: 400;
        }

        /* =============================================
           BOTTOM CTA
           ============================================= */
        .bottom-cta {
            background: rgba(244, 162, 97, 0.1);
            border: 1px solid rgba(244, 162, 97, 0.2);
            border-radius: 20px;
            padding: 50px;
            text-align: center;
            margin-top: 50px;
        }

        .bottom-cta h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 300;
            margin-bottom: 15px;
        }

        .bottom-cta h3 em {
            color: #f4a261;
            font-style: italic;
        }

        .bottom-cta p {
            font-size: 1rem;
            opacity: 0.6;
            margin-bottom: 30px;
        }

        .bottom-cta .book-direct-btn-large {
            width: auto;
            padding: 20px 60px;
        }

        /* =============================================
           RESPONSIVE
           ============================================= */
        @media (max-width: 900px) {
            .hotel-header {
                flex-direction: column;
                gap: 30px;
            }

            .booking-box {
                width: 100%;
                min-width: auto;
            }

            .content-grid {
                grid-template-columns: 1fr;
            }

            .verified-grid {
                grid-template-columns: 1fr;
            }

            .amenities-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .gallery-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 600px) {
            .hotel-name {
                font-size: 2.2rem;
            }

            .hero-image {
                height: 300px;
            }

            header {
                padding: 20px;
            }

            .amenities-grid {
                grid-template-columns: 1fr;
            }

            .policies-grid {
                grid-template-columns: 1fr;
            }

            .gallery-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <!-- BACKGROUND -->
    <div class="space-bg"></div>
    <div class="space-overlay"></div>

    <!-- HEADER -->
    <header>
        <a href="index.html" class="logo">
            <img src="diamond.jpg" alt="Diamond" class="logo-diamond">
