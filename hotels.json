                    <p class="hotel-location">
                        <span>📍</span> Baarsjesweg 24 · Amsterdam West
                    </p>
                    <div class="hotel-tags">
                        <span class="hotel-tag">Creative Hub</span>
                        <span class="hotel-tag">Workspace</span>
                        <span class="hotel-tag">Local Vibe</span>
                        <span class="hotel-tag">Romantic</span>
                    </div>
                </div>

