                        </div>
                        <div class="nearby-item">
                            <span>🏛️ Rijksmuseum</span>
                            <span class="distance">15 min tram</span>
                        </div>
                    </div>
                </div>

                <!-- GALLERY -->
                <div class="content-card full-width">
                    <h3 class="card-title">✦ Gallery</h3>
                    <div class="gallery-grid">
                        <div class="gallery-image" style="background-image: url('https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600');"></div>
                        <div class="gallery-image" style="background-image: url('https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=600');"></div>
                        <div class="gallery-image" style="background-image: url('https://images.unsplash.com/photo-1551882547-ff40c63fe5fa?w=600');"></div>
                        <div class="gallery-image" style="background-image: url('https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=600');"></div>
                        <div class="gallery-image" style="background-image: url('https://images.unsplash.com/photo-1596394516093-501ba68a0ba6?w=600');"></div>
                        <div class="gallery-image" style="background-image: url('https://images.unsplash.com/photo-1590490360182-c33d57733427?w=600');"></div>
                    </div>
                </div>

                <!-- POLICIES -->
                <div class="content-card full-width">
                    <h3 class="card-title">✦ Policies</h3>
                    <div class="policies-grid">
                        <div class="policy-item">
                            <span class="policy-label">Check-in</span>
                            <span class="policy-value">From 15:00</span>
                        </div>
                        <div class="policy-item">
                            <span class="policy-label">Check-out</span>
                            <span class="policy-value">Until 11:00</span>
                        </div>
                        <div class="policy-item">
                            <span class="policy-label">Cancellation</span>
                            <span class="policy-value">Free until 48h before</span>
                        </div>
                        <div class="policy-item">
                            <span class="policy-label">Children</span>
                            <span class="policy-value">Welcome (cribs available)</span>
                        </div>
                        <div class="policy-item">
                            <span class="policy-label">Pets</span>
